      "name": "Users",
      "item": [
        {
          "name": "users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "\r",
                  "if (res.data && res.data.length > 0) {\r",
                  "    const targetUser = res.data.find(user => user.role !== \"ADMIN\") || res.data[0];\r",
                  "    pm.environment.set(\"userId\", targetUser.id);\r",
                  "}\r",
                  ""
                ],
